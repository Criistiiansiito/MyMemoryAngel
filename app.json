{
  "expo": {
    "name": "MyMemoryAngel",
    "slug": "MyMemoryAngel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./frontend/assets/icons/splash.png",
    "resizeMode": "cover",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./frontend/assets/icons/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
          "UIBackgroundModes": ["audio"]
      }      
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./frontend/assets/icons/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
