{
  "expo": {
    "name": "MyMemoryAngel",
    "slug": "MyMemoryAngel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./frontend/assets/icons/splash.png",
    "resizeMode": "cover",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./frontend/assets/icons/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.criistiian.MyMemoryAngel"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./frontend/assets/icons/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.criistiian.MyMemoryAngel"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./frontend/assets/icons/adaptive-icon.png",
          "color": "#4D6BFE"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "21b5a544-b0df-4f8f-ba8d-7e5630aed0d2"
      }
    },
    "owner": "criistiian"
  }
}
